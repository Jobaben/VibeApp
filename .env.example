# Docker Compose environment overrides.
# Copy to .env and adjust. Every value is optional for local development;
# SECRET_KEY (and a real POSTGRES_PASSWORD) are required for production.

# Database password (also used in the backend DATABASE_URL)
POSTGRES_PASSWORD=stockfinder123

# development | production — production enables strict startup validation
ENVIRONMENT=development

# FastAPI debug mode; must be false in production
DEBUG=false

# JWT signing key — required when ENVIRONMENT=production.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# AI insight endpoints (requires an Anthropic API key)
LLM_ENABLED=false
ANTHROPIC_API_KEY=

# API URL baked into the frontend build at image-build time
VITE_API_URL=http://localhost:8000/api
