# Application
APP_NAME=VibeApp
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://vibeapp:vibeapp123@localhost:5432/vibeapp_db

# JWT Authentication
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Server
HOST=0.0.0.0
PORT=8000

# Stock Data API
# Real Yahoo Finance data is fetched by default, with automatic fallback to
# mock data whenever Yahoo blocks the request or the network is unavailable.
# Set to false to skip the network entirely (CI, offline development).
USE_REAL_STOCK_API=true

# Set to true to always use mock data (overrides USE_REAL_STOCK_API)
FORCE_MOCK_DATA=false

# Note: Yahoo Finance may block automated requests with 403 errors.
# For production, consider using a paid API service:
# - Alpha Vantage: https://www.alphavantage.co/
# - Financial Modeling Prep: https://financialmodelingprep.com/
# - IEX Cloud: https://iexcloud.io/

# LLM (AI insights) ----------------------------------------------------
# Get an API key at console.anthropic.com. Required when LLM_ENABLED=true.
ANTHROPIC_API_KEY=

# Set to false to disable LLM calls (returns sentinel insight + X-AI-Status: disabled).
LLM_ENABLED=true

# Anthropic model to use for insights.
LLM_MODEL=claude-sonnet-4-6

# Per-request timeout (seconds) forwarded to the Anthropic SDK.
LLM_TIMEOUT_SECONDS=30

# SDK-level retry budget for transient errors. Total retries = this value.
LLM_MAX_RETRIES=3
