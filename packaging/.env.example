# Optional configuration for VibeApp.
# Rename this file to ".env" (no name, just the extension) and restart the app.
#
# Everything here is optional. The app runs fine without it.

# --- AI insights (optional) ---------------------------------------------
# Get a key at https://console.anthropic.com, paste it below, and set
# LLM_ENABLED=true to turn on AI-powered stock insights.
ANTHROPIC_API_KEY=
LLM_ENABLED=false

# --- Live stock data (optional, advanced) -------------------------------
# By default the app uses built-in sample data so it works offline.
# Set to true to try fetching live data from Yahoo Finance (may be rate-limited).
USE_REAL_STOCK_API=false
